[gd_scene format=3 uid="uid://servicemenu"]

[ext_resource type="Script" path="res://scripts/systems/service_menu_ui.gd" id="1_ui"]

[node name="ServiceMenuUI" type="CanvasLayer"]
script = ExtResource("1_ui")
layer = 11

[node name="Panel" type="PanelContainer" parent="."]
anchor_left = 0.3
anchor_right = 0.7
anchor_top = 0.3
anchor_bottom = 0.75
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Panel"]
layout_mode = 2

[node name="Title" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Was möchtest du servieren?"
horizontal_alignment = 1

[node name="Wanted" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 14
text = "Gast möchte: ?"
horizontal_alignment = 1

[node name="TrustLbl" type="Label" parent="Panel/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.3, 0.8, 0.4, 1)
theme_override_font_sizes/font_size = 12
text = "Beziehung: Unbekannt"
horizontal_alignment = 1

[node name="Separator" type="HSeparator" parent="Panel/VBox"]
layout_mode = 2

[node name="Items" type="VBoxContainer" parent="Panel/VBox"]
layout_mode = 2
