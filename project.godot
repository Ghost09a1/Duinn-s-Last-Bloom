DebugUI="*res://scenes/ui/DebugUI.tscn"
SecuritySystem="*res://scripts/systems/security_system.gd"
QuestManager="*res://scripts/systems/quest_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2

